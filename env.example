# ── DATABASE ──────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/novabuk

# ── SERVER ────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── AUTH ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this

# ── CLOUDINARY (image uploads) ────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── EMAIL — Resend ────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The email address emails are sent FROM
# Must be verified in your Resend dashboard
FROM_EMAIL=NovaBuk <noreply@novabuk.com>

# ── FRONTEND URL (for reset password link) ────
# Development:
FRONTEND_URL=http://localhost:5500
# Production (update when deployed):
# FRONTEND_URL=https://novabukrepo.vercel.app

# ── ADMIN (initial setup) ─────────────────────
ADMIN_EMAIL=admin@novabuk.com
ADMIN_PASSWORD=change_me_in_production

# ── CONTACT FORM ────────────────────────────────
# Email address that receives contact form submissions
CONTACT_EMAIL=hello@novabuk.com
